generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                  String             @id @default(uuid())
  matricule           String             @unique
  firstName           String
  lastName            String
  parentName          String
  parentPhone         String
  parentEmail         String?
  halaqaId            String
  etape               String
  currentSurahNum     Int?
  currentVersetNum    Int?
  currentHizbNum      Int?
  currentHizbFraction Float?
  khatmatCount        Int                @default(0)
  dailyWardHizbs      Int                @default(0)
  score               Int                @default(0)
  balanceDue          Float              @default(0)
  monthlyFee          Float              @default(0)
  age                 Int?
  regime              String?
  gender              String?
  nationality         String?
  status              String?
  fatherName          String?
  fatherPhone         String?
  guardianName        String?
  guardianPhone       String?
  guardianRelation    String?
  motherName          String?
  motherPhone         String?
  attendance          AttendanceRecord[]
  payments            PaymentRecord[]
  lessons             QuranLesson[]
  halaqa              Halaqa             @relation(fields: [halaqaId], references: [id])
  medals              StudentMedal[]
}

model StudentMedal {
  id        String  @id @default(uuid())
  studentId String
  name      String
  icon      String
  date      String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Halaqa {
  id           String    @id @default(uuid())
  name         String
  teacherName  String
  maxCapacity  Int       @default(20)
  building     String?
  description  String?
  isActive     Boolean   @default(true)
  level        String?
  phoneTeacher String?
  schedule     String?
  students     Student[]
}

model QuranLesson {
  id                    String  @id @default(uuid())
  studentId             String
  date                  String
  evaluation            String
  type                  String
  startSurah            Int?
  startVerset           Int?
  endSurah              Int?
  endVerset             Int?
  startHizb             Int?
  startHizbFraction     Float?
  endHizb               Int?
  endHizbFraction       Float?
  comments              String?
  murajaahEndFraction   Float?
  murajaahEndHizb       Int?
  murajaahEvaluation    String?
  murajaahStartFraction Float?
  murajaahStartHizb     Int?
  versesCount           Int?
  student               Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id        String  @id @default(uuid())
  studentId String
  date      String
  status    String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id            String  @id @default(uuid())
  studentId     String
  date          String
  amount        Float
  purpose       String
  receiptNumber String
  recordedBy    String
  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Staff {
  id     String @id @default(uuid())
  name   String
  role   String
  phone  String
  status String @default("Actif")
}
